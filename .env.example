# TOOL_GET_DATETIME_ENABLED=true
# TOOL_SUM_NUMBERS_ENABLED=true
# TOOL_SCORE_GRADE_ENABLED=true
# TOOL_TO_UPPERCASE_ENABLED=true
# TOOL_CREATE_TODO_LIST_ENABLED=true
# TOOL_ANALYZE_CAUSAL_CHAIN_ENABLED=true

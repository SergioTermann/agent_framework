# 环境变量配置模板
# 复制此文件为 .env 并填入你的配置

# ============================================================================
# LLM API 配置
# ============================================================================

# 硅基流动 API Key（推荐）
# 获取地址: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=your-siliconflow-api-key-here

# OpenAI API Key（可选）
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# 默认模型
DEFAULT_MODEL=Qwen/Qwen3-VL-32B-Instruct

# API Base URL
BASE_URL=https://api.siliconflow.cn/v1

# 通用 OpenAI-Compatible 配置（优先级高于上面的 DEFAULT_MODEL / BASE_URL）
# 适合统一接入 vLLM / Ollama / OpenAI / SiliconFlow
LLM_PROVIDER=openai-compatible
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# LLM_BASE_URL=http://127.0.0.1:8000/v1
# LLM_API_KEY=

# vLLM 本地部署（可选）
# 启动示例：
#   python -m vllm.entrypoints.openai.api_server --model Qwen/Qwen2.5-7B-Instruct --host 127.0.0.1 --port 8000
# 然后配置：
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# VLLM_BASE_URL=http://127.0.0.1:8000/v1
# VLLM_API_KEY=
# 如果 Web 服务运行在 Windows，但 vLLM 跑在 WSL，可额外配置：
# VLLM_WSL_DISTRO=Ubuntu-24.04
# VLLM_WSL_PYTHON=/home/your-user/vllm-env/bin/python

# ============================================================================
# 平台配置
# ============================================================================

# 密钥（用于 JWT Token 签名，生产环境请修改）
SECRET_KEY=agent-framework-secret-key-change-in-production

# 服务器配置
HOST=0.0.0.0
PORT=5000
DEBUG=False

# ============================================================================
# 数据库配置
# ============================================================================

# 数据存储路径
DATA_DIR=./data

# ============================================================================
# 内存后端配置
# ============================================================================
# 可选值: local / reme / viking
MEMORY_BACKEND=local
MEMORY_BACKEND_FALLBACK=true

# ReMe 侧车模式
# 启用后，主进程会通过 HTTP 调用隔离在 .venv_reme_memory 中的 ReMe 服务
# 若未单独设置 REME_*，会回退复用全局 LLM_* / BASE_URL / OPENAI_* 配置
# 若 LLM_PROVIDER=vllm，建议显式提供独立的 REME_EMBEDDING_* 或 EMBEDDING_* 端点
REME_ENABLED=false
REME_SIDECAR_ENABLED=true
REME_SIDECAR_AUTO_START=true
REME_SIDECAR_BASE_URL=http://127.0.0.1:8765
REME_SIDECAR_HOST=127.0.0.1
REME_SIDECAR_PORT=8765
REME_SIDECAR_VENV=.venv_reme_memory
REME_SIDECAR_WORKDIR=.reme-sidecar
REME_SIDECAR_TIMEOUT=45
REME_SIDECAR_REQUEST_TIMEOUT=10
# 仅当嵌入模型需要显式维度时再设置，例如 768 / 1024
# REME_EMBEDDING_DIMENSIONS=768
# 如果 ReMe 需要独立的模型或嵌入端点，可在这里配置
# 对于本地聊天 vLLM，这里的 Embedding 端点通常必须单独提供，不能直接复用聊天端口
# REME_LLM_API_KEY=
# REME_LLM_BASE_URL=
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# REME_EMBEDDING_API_KEY=
# REME_EMBEDDING_BASE_URL=

# ByteDance OpenViking / VikingDB
VIKING_ENABLED=false
# VIKING_HOST=api-knowledgebase.mlp.cn-beijing.volces.com
# VIKING_REGION=cn-beijing
# VIKING_ACCESS_KEY=
# VIKING_SECRET_KEY=
# VIKING_SCHEME=http
# VIKING_TIMEOUT=30

# ============================================================================
# Xinference 本地部署（可选）
# ============================================================================
# Xinference 本地部署通常不需要真实 API Key
# 默认地址: http://localhost:9997/v1
#
# 启动 Xinference:
#   pip install xinference
#   xinference-local --host 0.0.0.0 --port 9997
#
# 部署模型:
#   xinference launch --model-name qwen2.5-instruct --model-size-in-billions 7

# ============================================================================
# Web 搜索配置（SearXNG）
# ============================================================================
# SearXNG 实例地址
# 快速启动: docker run -d -p 8888:8080 searxng/searxng
SEARXNG_BASE_URL=http://localhost:8888
WEB_SEARCH_ENABLED=true

# ============================================================================
# 天气服务配置（OpenWeatherMap）
# ============================================================================
# 免费注册: https://openweathermap.org/api
WEATHER_API_KEY=your-openweathermap-api-key-here
WEATHER_ENABLED=true

# ============================================================================
# 旅行服务配置（高德地图）
# ============================================================================
# 免费申请: https://console.amap.com/dev/key/app
AMAP_API_KEY=your-amap-api-key-here
TRAVEL_ENABLED=true

# ============================================================================
# 工具开关（按需禁用，默认全部启用）
# ============================================================================
